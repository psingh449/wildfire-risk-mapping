flowchart TD

subgraph DS[Data Sources]
    direction LR
    A[Wildfire hazard dataset]
    B[Land cover dataset]
    C[Population and housing census]
    D[Community demographics survey]
    E[Critical facilities dataset]
    F[Road network map data]
    G[Historical wildfire perimeters]
    H[Federal county risk benchmark]
end

subgraph ING[Data Collection]
    I1[Load wildfire hazard data]
    I2[Load vegetation and land cover data]
    I3[Load population data]
    I4[Load housing unit data]
    I5[Load social vulnerability data]
    I6[Load fire station and hospital data]
    I7[Load road network data]
    I8[Load historical fire boundaries]
    I9[Load federal benchmark risk data]
end

DS --> ING

subgraph PRE[Data Preparation]
    J1[Standardize map projection]
    J2[Clip all data to study area]
    J3[Build analysis blocks with IDs]
    J4[Create block center points]
end

ING --> PRE

subgraph FE[Feature Building]

    subgraph HZ[Hazard Features]
        H1[Wildfire likelihood by block]
        H2[Vegetation fuel intensity]
        H3[Closeness to forested areas]
        H4[Overall hazard score]
    end

    subgraph EX[Exposure Features]
        E1[People exposed in each block]
        E2[Homes exposed in each block]
        E3[Estimated property value exposed]
        E4[Overall exposure score]
    end

    subgraph VL[Vulnerability Features]
        V1[Poverty vulnerability]
        V2[Elderly vulnerability]
        V3[Transportation access vulnerability]
        V4[Overall vulnerability score]
    end

    subgraph RS[Resilience Features]
        R1[Access to fire stations]
        R2[Access to hospitals]
        R3[Road connectivity support]
        R4[Overall resilience score]
    end

end

PRE --> FE

subgraph MODEL[Risk Modeling]
    M1[Compute overall wildfire risk]
    M2[Estimate annual economic loss]
    M3[Scale loss score for map display]
end

FE --> MODEL

subgraph VAL[Validation and Quality Checks]
    VLD1[Map each block to its county]
    VLD2[Compute county-level risk]
    VLD3[Compute county-level loss]
    VLD4[Compare with federal benchmark]
    VLD5[Check overlap with past fires]
    VLD6[Evaluate prediction quality]
    VLD7[Measure concentration of risk]
    VLD8[Measure inequality of risk]
end

MODEL --> VAL

subgraph EXP[Output and Reporting]
    X1[Export final risk GeoJSON]
    X2[Export validation summary report]
end

MODEL --> EXP
VAL --> EXP

