    end

    subgraph EX[Exposure]
        E1[Build population exposure feature<br/>-> population exposure]
        E2[Build housing exposure feature<br/>-> housing exposure]
        E3[Build building value exposure feature<br/>-> building value exposure]
        E4[Build overall exposure score<br/>-> exposure score]
    end

    subgraph VL[Vulnerability]
        V1[Build poverty vulnerability feature<br/>-> poverty vulnerability]
        V2[Build elderly vulnerability feature<br/>-> elderly vulnerability]
        V3[Build uninsured vulnerability feature<br/>-> uninsured vulnerability]
