    end

    subgraph RS[Resilience]
        R1[Build vehicle access resilience feature<br/>-> vehicle access resilience]
        R2[Build income resilience feature<br/>-> income resilience]
        R3[Build internet access resilience feature<br/>-> internet resilience]
        R4[Build overall resilience score<br/>-> resilience score]
    end

end

PRE --> FE

subgraph MODEL[MODEL]
    M1[Calculate wildfire risk score<br/>-> risk score] ---
