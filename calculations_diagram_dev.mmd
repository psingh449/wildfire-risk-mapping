flowchart TD

subgraph DS["🔍 DATA SOURCES (9 External Data Providers)"]
    direction LR
    A["🔥 WHP (USFS)<br/>Source: raster zonal stats when available<br/>Cache: data/real_cache/counties/{FIPS}/whp/wildfire/"] 
    B["🌲 Landcover proxy (OSM-based)<br/>Source: OSM polygons (proxy for NLCD)<br/>Cache: data/real_cache/counties/{FIPS}/nlcd/{vegetation|forest_distance}/"] 
    C["👥 Census PL 2020 (Pop)<br/>API: api.census.gov/data/2020/dec/pl<br/>Cache: data/real_cache/counties/{FIPS}/census_pl_2020/population/"]
    D["🏠 Census PL 2020 (Housing)<br/>API: api.census.gov/data/2020/dec/pl<br/>Cache: data/real_cache/counties/{FIPS}/census_pl_2020/housing/"]
    E["📊 ACS 2021 5-year (BG/tract)<br/>API: api.census.gov/data/2021/acs/acs5<br/>Cache: data/real_cache/counties/{FIPS}/acs_2021_5yr/*"]
    H["🔴 MTBS perimeters (optional)<br/>Cache: data/external/mtbs_fire_perimeters.geojson<br/>Use: Experiments 3–4 only"]
    I["📋 FEMA NRI counties (optional)<br/>Cache: data/external/fema_nri_county.csv<br/>Use: Experiment 1 only"]
    A --- B --- C --- D --- E --- F --- G --- H --- I
end

subgraph ING["📥 INGESTION LAYER<br/>File: src/ingestion/load_*.py + src/utils/real_data.py<br/>Fetches raw data from APIs and stores locally"]
    I1["fetch_whp_data<br/>→ hazard_wildfire<br/>Function: compute_hazard_wildfire<br/>Type: Raster zonal stats (mean)"]
    I2["fetch_nlcd_data<br/>→ hazard_vegetation<br/>Function: compute_hazard_vegetation<br/>Type: Pixel classification"]
    I3["fetch_census_pop<br/>→ exposure_population<br/>Function: compute_exposure_population_real<br/>Type: Census API call + mapping"]
    I4["fetch_census_housing<br/>→ exposure_housing<br/>Function: compute_exposure_housing_real<br/>Type: Census API call + mapping"]
    I5["fetch_acs_data<br/>→ vuln_poverty, vuln_elderly, vuln_uninsured<br/>→ res_vehicle_access, res_median_household_income, res_internet_access<br/>→ exposure_building_value<br/>Functions: compute_vuln_*/compute_res_*_real<br/>Type: ACS API call + (optional) tract fallback"]
    I8["fetch_fire_perimeters<br/>→ fire_perimeters_dataset<br/>Function: For validation only<br/>Type: Historical fire boundaries"]
    I9["fetch_fema_nri<br/>→ fema_nri_dataset<br/>Function: For validation comparison<br/>Type: County-level risk index"]
    I1 --- I2 --- I3 --- I4 --- I5 --- I6 --- I7 --- I8 --- I9
end

DS --> ING

subgraph PRE["🧹 PREPROCESSING LAYER<br/>File: src/preprocessing/preprocess_blocks.py<br/>Standardize and clean geographic data"]
    J1["standardize_crs<br/>→ EPSG:3857 Web Mercator<br/>Ensures all layers use same coord system"]
    J2["clip_to_butte_county<br/>→ Remove blocks outside boundary<br/>Ensures geographic consistency"]
    J3["generate_blocks_with_block_id<br/>→ Assign unique IDs<br/>Used for joins and referencing"]
    J4["compute_centroids<br/>→ Center point of each block<br/>Used for distance calculations"]
    J1 --- J2 --- J3 --- J4
end

ING --> PRE

subgraph FE["⚙️ FEATURE ENGINEERING LAYER<br/>File: src/pipeline/feature_pipeline.py + src/features/*.py<br/>Calculate 17 derived metrics from raw data"]

    subgraph HZ["🔥 HAZARD (3 features → 1 score)<br/>Likelihood and intensity of wildfire"]
        H1["compute_hazard_wildfire<br/>Source: WHP raster<br/>Formula: mean pixel value<br/>Range: 0-1"]
        H2["compute_hazard_vegetation<br/>Source: NLCD classification<br/>Formula: forest pixels / total<br/>Range: 0-1"]
        H3["compute_hazard_forest_distance<br/>Source: NLCD forest polygons<br/>Formula: 1/(1+distance_km)<br/>Range: 0-1"]
        H4["compute_hazard_score<br/>Formula: Σ(weight_i * norm(feat_i))<br/>for weight_group='hazard_score'<br/>Weights: 0.333 each<br/>Range: 0-1"]
        H1 --> H4
        H2 --> H4
        H3 --> H4
    end

    subgraph EX["👥 EXPOSURE (3 features → 1 score)<br/>Number of people and assets at risk"]
        E1["compute_exposure_population<br/>Source: Census API (P1_001N)<br/>Formula: Direct mapping by GEOID<br/>Type: Integer (persons)"]
        E2["compute_exposure_housing<br/>Source: Census API (H1_001N)<br/>Formula: Direct mapping by GEOID<br/>Type: Integer (units)"]
        E3["compute_exposure_building_value<br/>Source: ACS (B25077_001E)<br/>Formula: housing * median_value_BG<br/>Type: Float (USD)"]
        E4["compute_exposure_score<br/>Formula: Σ(weight_i * norm(feat_i))<br/>for weight_group='exposure_score'<br/>Weights: 0.333 each<br/>Range: 0-1"]
        E1 --> E4
        E2 --> E4
        E3 --> E4
    end

    subgraph VL["😟 VULNERABILITY (3 features → 1 score)<br/>Social factors that increase risk"]
        V1["compute_vuln_poverty<br/>Source: ACS (B17001_002E/B17001_001E)<br/>Formula: poverty_persons / total_persons<br/>Type: Normalized rate (0-1)"]
        V2["compute_vuln_elderly<br/>Source: ACS (B01001_020E..049E)<br/>Formula: elderly_pop / total_pop<br/>Type: Normalized ratio (0-1)"]
        V3["compute_vuln_uninsured<br/>Source: ACS (B27010 bins)<br/>Formula: uninsured / total<br/>Type: Normalized ratio (0-1)"]
        V4["compute_vulnerability_score<br/>Formula: Σ(weight_i * norm(feat_i))<br/>for weight_group='vulnerability_score'<br/>Weights: 0.4, 0.3, 0.3<br/>Range: 0-1"]
        V1 --> V4
        V2 --> V4
        V3 --> V4
    end

    subgraph RS["🛡️ RESILIENCE (3 features → 1 score)<br/>Resources that reduce impact and aid recovery"]
        R1["compute_res_vehicle_access<br/>Source: ACS (B08201)<br/>Formula: 1 - (no_vehicle / total)<br/>Type: Share (0-1)"]
        R2["compute_res_median_household_income<br/>Source: ACS (B19013_001E)<br/>Type: USD (normalized for score)"]
        R3["compute_res_internet_access<br/>Source: ACS (B28002)<br/>Formula: 1 - (no_internet / total)<br/>Type: Share (0-1)"]
        R4["compute_resilience_score<br/>Formula: Σ(weight_i * norm(feat_i))<br/>for weight_group='resilience_score'<br/>Weights: from calculations.csv<br/>Range: 0-1"]
        R1 --> R4
        R2 --> R4
        R3 --> R4
    end

end

PRE --> FE

subgraph MODEL["🎲 RISK MODEL LAYER<br/>File: src/models/risk_model.py<br/>Combine components into final risk metrics"]
    M1["compute_risk_score<br/>Formula: H × E × V × (1-R)<br/>Interpretation: Multiply hazards,<br/>multiply by exposure,<br/>multiply by vulnerability,<br/>reduce by resilience<br/>Range: 0-1"]
    M2["compute_eal<br/>(Expected Annual Loss)<br/>Formula: risk_score × exposure_building_value<br/>Interpretation: Dollar loss per year<br/>Type: Float (USD)<br/>Units: $ per year"]
    M3["normalize_eal<br/>(Min-max normalization)<br/>Formula: (eal - min) / (max - min)<br/>Transforms EAL to 0-1 scale<br/>Range: 0-1"]
    M1 --> M2 --> M3
end

FE --> MODEL

subgraph VAL["✅ VALIDATION LAYER<br/>File: src/validation/metrics.py + src/utils/validator.py<br/>Checks data quality and model reasonableness"]
    VLD1["aggregate_block_to_county<br/>→ block_to_county_mapping<br/>Validates geographic aggregation"]
    VLD2["compute_county_risk_from_blocks<br/>→ county_risk<br/>Aggregation: mean(risk_score)<br/>Validates county-level scores"]
    VLD3["compute_county_eal_from_blocks<br/>→ county_eal<br/>Aggregation: sum(eal)<br/>Validates total county loss"]
    VLD4["compare_with_fema_nri<br/>→ fema_nri_comparison<br/>Compares our risk with FEMA's<br/>Metric: Correlation coefficient<br/>Target: > 0.7 (reasonable agreement)"]
    VLD5["compute_historical_fire_overlap<br/>→ fire_overlap_ratio<br/>Computed only when MTBS perimeters exist; else null"]
    VLD6["compute_auc_fire_prediction<br/>→ auc_score<br/>Computed only when MTBS perimeters exist; else null"]
    VLD7["compute_risk_concentration<br/>→ risk_concentration<br/>Checks: % of risk in top 10%<br/>Measures: Risk clustering"]
    VLD8["compute_lorenz_curve<br/>→ gini_risk<br/>Calculates: Gini coefficient<br/>Measures: Risk inequality"]
    VLD1 --> VLD2 --> VLD3 --> VLD4
    VLD5 --> VLD6 --> VLD7 --> VLD8
end

MODEL --> VAL

subgraph EXP["📤 EXPORT LAYER<br/>File: src/pipeline/export.py<br/>Write results for visualization"]
    X1["export_geojson<br/>→ data/processed/blocks.geojson<br/>Contains: All 200 blocks<br/>With: All 17 features + scores<br/>Format: GeoJSON (web-ready)"]
    X2["export_validation_report<br/>→ data/processed/validation_report.json<br/>Contains: Validation metrics<br/>Format: JSON (machine-readable)"]
end

MODEL --> EXP
VAL --> EXP

